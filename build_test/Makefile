NF_EngineTests: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 NF_EngineTests
.PHONY : NF_EngineTests

# fast build rule for target.
NF_EngineTests/fast:
	$(MAKE) $(MAKESILENT) -f Tests/CMakeFiles/NF_EngineTests.dir/build.make Tests/CMakeFiles/NF_EngineTests.dir/build
.PHONY : NF_EngineTests/fast

