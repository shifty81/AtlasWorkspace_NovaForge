{
  "project": {
    "name": "NovaForge",
    "type": "unified-monorepo",
    "version": "0.1.0-reset",
    "defaultWorld": "DevWorld",
    "defaultStartupMode": "Editor"
  },
  "paths": {
    "contentRoot": "Content",
    "configRoot": "Config",
    "saveRoot": "Saved",
    "logRoot": "Saved/Logs",
    "atlasAIRoot": "AtlasAI",
    "toolsRoot": "Tools",
    "archiveRoot": "Archive"
  },
  "phases": [
    "Phase0_Bootstrap",
    "Phase1_DevWorldOnly",
    "Phase2_VoxelRuntimeOnly",
    "Phase3_FirstInteractionLoopOnly",
    "Phase4_VoxelMeshRendering",
    "Phase5_MovementFPSCamera",
    "Phase6_MultiplayerFoundation"
  ],
  "rules": {
    "voxelAuthoritative": true,
    "editorShipsWithGame": false,
    "allowSuiteFeaturesInRepo": true,
    "atlasAIBrokerEnabled": true,
    "workspaceEnabled": true
  }
}
