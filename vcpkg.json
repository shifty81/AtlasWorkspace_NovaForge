{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "novaforge",
  "version": "0.1.0",
  "description": "NovaForge — unified engine, editor, game, AI, tools monorepo",
  "dependencies": [
    {
      "name": "glfw3",
      "platform": "windows | osx"
    },
    {
      "name": "opengl",
      "platform": "windows"
    },
    {
      "name": "imgui",
      "features": [
        "dx12-binding",
        "vulkan-binding",
        "opengl3-binding",
        "glfw-binding"
      ]
    },
    "vulkan-headers",
    "openal-soft",
    "bullet3",
    "nlohmann-json",
    "spdlog",
    "entt",
    "cereal",
    "stb",
    "assimp",
    "fmt",
    "glm"
  ],
  "builtin-baseline": "7516a02de04e8f8ff4e4beb8f8eb00552b67a5f2"
}
