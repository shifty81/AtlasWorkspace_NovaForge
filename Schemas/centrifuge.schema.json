{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novaforge.dev/schemas/centrifuge.schema.json",
  "title": "Centrifuge Configuration",
  "description": "Defines a centrifuge processing station at a given tier.",
  "type": "object",
  "required": ["tier", "speed_multiplier", "queue_size", "power_draw"],
  "properties": {
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Centrifuge upgrade tier."
    },
    "speed_multiplier": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Processing speed multiplier (1.0 = base speed)."
    },
    "queue_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16,
      "description": "Maximum number of queued processing jobs."
    },
    "power_draw": {
      "type": "number",
      "minimum": 0,
      "description": "Continuous power consumption in kilowatts."
    },
    "supported_recipes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recipe IDs this centrifuge tier can process."
    }
  },
  "additionalProperties": false
}
